---
import Base from '../layouts/Base.astro';
import db from '../data/power_stations.json';
import { fullName, dollarsPerWh } from '../lib/utils.js';

const stations = db.power_stations;
const brands = new Set(stations.map((s) => s.brand)).size;
const bestValue = [...stations].sort((a, b) => dollarsPerWh(a) - dollarsPerWh(b)).slice(0, 4);
const newest = [...stations].sort((a, b) => b.release_year - a.release_year).slice(0, 4);

const title = 'WattLibrary — Portable Power Station Specs, Runtimes & Compatibility';
const description = `A structured database of ${stations.length} portable power stations: verified capacity, inverter output, chemistry, solar limits and appliance runtimes.`;
---
<Base {title} {description}>
  <section class="hero" slot="hero">
    <div class="wrap">
      <p class="eyebrow">The portable power station database</p>
      <h1>Power station specs, without the marketing gloss</h1>
      <p class="lead">
        We keep a structured database of {stations.length} portable power stations from {brands} brands. Real capacity, inverter output,
        battery chemistry, solar limits. The numbers come from spec sheets and manuals, get checked before they go live, and read
        the same way for every brand, so you can compare like for like.
      </p>
      <div class="btn-row">
        <a href="/power-stations/" class="btn">Browse all {stations.length} models</a>
        <a href="/compare/" class="btn btn-ghost">Head-to-head comparisons</a>
      </div>
      <div class="kpis" style="max-width:560px;">
        <div class="kpi"><b>{stations.length}</b> models tracked</div>
        <div class="kpi"><b>{brands}</b> brands</div>
        <div class="kpi"><b>26</b> specs per model</div>
      </div>
    </div>
  </section>

  <h2 style="margin-top:.5rem;">Best value per watt-hour <span class="muted" style="font-weight:400; font-size:.85rem;">(launch price)</span></h2>
  <div class="grid">
    {bestValue.map((s) => (
      <div class="card">
        <a href={`/power-stations/${s.slug}/`}>{fullName(s)}</a>
        <p class="sub">{s.capacity_wh.toLocaleString()}Wh · {s.chemistry} · <b style="color:var(--accent-deep);">${dollarsPerWh(s).toFixed(2)}/Wh</b></p>
      </div>
    ))}
  </div>

  <h2>Recently released</h2>
  <div class="grid">
    {newest.map((s) => (
      <div class="card">
        <a href={`/power-stations/${s.slug}/`}>{fullName(s)}</a>
        <p class="sub">{s.release_year} · {s.capacity_wh.toLocaleString()}Wh · {s.ac_output_w.toLocaleString()}W</p>
      </div>
    ))}
  </div>

  <h2>Why another power station site?</h2>
  <p style="max-width:660px;">
    A product page will happily call a 268Wh box a "solar generator". It won't mention that the inverter eats roughly 15% of
    every charge, or that an NMC pack rated for 500 cycles is basically a consumable next to a 3,000-cycle LiFePO4 one, or that
    your panel needs to land inside a specific voltage window before the unit will accept a single watt from it.
  </p>
  <p style="max-width:660px;">
    That gap is what this site exists for. We normalize the numbers brands report in incompatible ways, flag the ones they'd
    rather you didn't compare, and show the working behind every runtime estimate. When we're not sure about a figure, it
    stays out of the database until we are.
  </p>
</Base>
