---
import Base from '../../layouts/Base.astro';
import db from '../../data/power_stations.json';
import pairsData from '../../data/compare_pairs.json';
import { fullName, capacityClass } from '../../lib/utils.js';
import { pairSlug } from '../../lib/compare.js';

const bySlug = Object.fromEntries(db.power_stations.map((s) => [s.slug, s]));
const pairs = pairsData.pairs.map((p) => ({ a: bySlug[p.a], b: bySlug[p.b] }));

const groups = {};
for (const p of pairs) {
  const g = capacityClass(Math.min(p.a.capacity_wh, p.b.capacity_wh));
  (groups[g] ??= []).push(p);
}

const title = `Power Station Comparisons: ${pairs.length} Head-to-Head Matchups`;
const description = `Side-by-side spec comparisons of popular power stations — EcoFlow, Anker, Bluetti, Jackery — with per-row winners and data-driven verdicts.`;
---
<Base {title} {description}>
  <h1>Head-to-head comparisons</h1>
  <p class="muted">Every comparison is generated from the same database, so the numbers are consistent across pages — no cherry-picking.</p>

  {Object.entries(groups).map(([group, list]) => (
    <>
      <h2>{group}</h2>
      <div class="grid">
        {list.map((p) => (
          <div class="card">
            <a href={`/compare/${pairSlug(p.a, p.b)}/`}>{fullName(p.a)} vs {fullName(p.b)}</a>
            <p class="muted" style="margin:0.3rem 0 0; font-size:0.85rem;">
              {p.a.capacity_wh.toLocaleString()}Wh vs {p.b.capacity_wh.toLocaleString()}Wh
            </p>
          </div>
        ))}
      </div>
    </>
  ))}
</Base>
