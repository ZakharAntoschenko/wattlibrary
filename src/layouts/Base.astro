---
const { title, description, schema } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <style>
    :root {
      --ink: #1a2332; --muted: #5a6b82; --line: #e3e8ef;
      --accent: #0d7a5f; --accent-soft: #e6f4f0; --bg: #ffffff; --bg-alt: #f7f9fb;
      --warn: #b45309;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font: 16px/1.6 system-ui, -apple-system, "Segoe UI", sans-serif; color: var(--ink); background: var(--bg); }
    a { color: var(--accent); }
    header.site { border-bottom: 1px solid var(--line); background: var(--bg); }
    header.site .wrap { display: flex; align-items: baseline; gap: 1.5rem; }
    .wrap { max-width: 960px; margin: 0 auto; padding: 0.9rem 1rem; }
    .logo { font-weight: 800; font-size: 1.15rem; color: var(--ink); text-decoration: none; letter-spacing: -0.02em; }
    .logo span { color: var(--accent); }
    nav.main a { color: var(--muted); text-decoration: none; margin-right: 1rem; font-size: 0.95rem; }
    nav.main a:hover { color: var(--accent); }
    main .wrap { padding-top: 1.6rem; padding-bottom: 3rem; }
    h1 { font-size: 1.7rem; line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.4rem; }
    h2 { font-size: 1.25rem; margin-top: 2.2rem; }
    table { border-collapse: collapse; width: 100%; font-size: 0.95rem; }
    th, td { text-align: left; padding: 0.45rem 0.7rem; border-bottom: 1px solid var(--line); }
    thead th { background: var(--bg-alt); font-weight: 600; }
    .pill { display: inline-block; background: var(--accent-soft); color: var(--accent); border-radius: 999px; padding: 0.1rem 0.65rem; font-size: 0.8rem; font-weight: 600; }
    .muted { color: var(--muted); }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
    .card { border: 1px solid var(--line); border-radius: 10px; padding: 1rem; }
    .card a { text-decoration: none; font-weight: 600; color: var(--ink); }
    .card a:hover { color: var(--accent); }
    .kpis { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 0.8rem 0 0.2rem; }
    .kpi { background: var(--bg-alt); border: 1px solid var(--line); border-radius: 8px; padding: 0.5rem 0.9rem; font-size: 0.9rem; }
    .kpi b { display: block; font-size: 1.05rem; }
    .crumbs { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.8rem; }
    .crumbs a { color: var(--muted); }
    footer.site { border-top: 1px solid var(--line); margin-top: 2rem; color: var(--muted); font-size: 0.85rem; }
    .disclosure { background: var(--bg-alt); border: 1px solid var(--line); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.83rem; color: var(--muted); margin: 1.2rem 0; }
  </style>
</head>
<body>
  <header class="site">
    <div class="wrap">
      <a class="logo" href="/">Watt<span>Library</span></a>
      <nav class="main">
        <a href="/power-stations/">All power stations</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>
  <main><div class="wrap"><slot /></div></main>
  <footer class="site">
    <div class="wrap">
      <p>© {new Date().getFullYear()} WattLibrary — an independent portable power station database. Specifications are compiled from manufacturer documentation and verified before publishing.</p>
      <p>As an Amazon Associate and partner of several brands, we may earn a commission from qualifying purchases made through links on this site, at no extra cost to you.</p>
    </div>
  </footer>
</body>
</html>
