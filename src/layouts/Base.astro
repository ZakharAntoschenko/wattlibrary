---
const { title, description, schema } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0e8a63" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="WattLibrary" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <style is:global>
    :root {
      --ink: #16202e; --ink-2: #334155; --muted: #64748b; --line: #e2e8f0;
      --accent: #0e8a63; --accent-deep: #0a6b4d; --accent-soft: #e7f6f0; --accent-line: #bfe8da;
      --bg: #ffffff; --alt: #f8fafc; --amber: #b45309; --amber-soft: #fef3e2;
      --radius: 12px; --shadow: 0 1px 2px rgba(22,32,46,.05), 0 4px 16px -8px rgba(22,32,46,.08);
      --shadow-up: 0 2px 4px rgba(22,32,46,.06), 0 12px 28px -12px rgba(22,32,46,.16);
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    body {
      margin: 0; color: var(--ink); background: var(--bg);
      font: 16px/1.65 system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
      text-rendering: optimizeLegibility;
    }
    a { color: var(--accent-deep); text-decoration-thickness: 1px; text-underline-offset: 2px; }
    .wrap { max-width: 1024px; margin: 0 auto; padding: 0 1.1rem; }

    /* ---------- Header ---------- */
    header.site {
      position: sticky; top: 0; z-index: 50;
      background: rgba(255,255,255,.86); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    header.site .wrap { display: flex; align-items: center; gap: 1rem; height: 3.4rem; }
    .logo { display: flex; align-items: center; gap: .45rem; font-weight: 800; font-size: 1.12rem; color: var(--ink); text-decoration: none; letter-spacing: -.02em; }
    .logo svg { flex: none; }
    .logo b { color: var(--accent); font-weight: 800; }
    nav.main { margin-left: auto; display: flex; gap: .2rem; }
    nav.main a {
      color: var(--ink-2); text-decoration: none; font-size: .92rem; font-weight: 550;
      padding: .42rem .7rem; border-radius: 8px;
    }
    nav.main a:hover { background: var(--accent-soft); color: var(--accent-deep); }

    /* ---------- Type ---------- */
    main .wrap { padding-top: 1.9rem; padding-bottom: 3.5rem; }
    h1 { font-size: clamp(1.55rem, 4.2vw, 2.15rem); line-height: 1.18; letter-spacing: -.025em; margin: 0 0 .45rem; text-wrap: balance; }
    h2 { font-size: clamp(1.18rem, 2.6vw, 1.38rem); letter-spacing: -.015em; margin: 2.4rem 0 .8rem; }
    h3 { font-size: 1.02rem; margin: 1.2rem 0 .25rem; }
    p { margin: .5rem 0 .9rem; }
    .lead { font-size: 1.06rem; color: var(--ink-2); max-width: 640px; }
    .muted { color: var(--muted); }
    .eyebrow { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--accent-deep); margin: 0 0 .3rem; }

    /* ---------- Chips / pills ---------- */
    .pill {
      display: inline-block; background: var(--accent-soft); color: var(--accent-deep);
      border: 1px solid var(--accent-line); border-radius: 999px;
      padding: .18rem .75rem; font-size: .8rem; font-weight: 650;
    }
    .pill-warn { background: var(--amber-soft); color: var(--amber); border-color: #f3ddbe; }

    /* ---------- KPI stat cards ---------- */
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(128px, 1fr)); gap: .6rem; margin: 1.1rem 0 .4rem; }
    .kpi {
      background: var(--alt); border: 1px solid var(--line); border-radius: var(--radius);
      padding: .7rem .85rem; font-size: .82rem; color: var(--muted);
    }
    .kpi b { display: block; font-size: 1.18rem; color: var(--ink); letter-spacing: -.02em; margin-bottom: .1rem; }

    /* ---------- Tables ---------- */
    .tbl { border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; margin: 1rem 0 1.4rem; background: var(--bg); }
    .tbl-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table { border-collapse: collapse; width: 100%; font-size: .93rem; }
    th, td { text-align: left; padding: .58rem .85rem; border-bottom: 1px solid var(--line); white-space: nowrap; }
    tbody th { white-space: normal; }
    tbody tr:last-child th, tbody tr:last-child td { border-bottom: 0; }
    thead th { background: var(--alt); font-weight: 650; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); }
    tbody tr:nth-child(even) { background: #fbfcfe; }
    tbody th { font-weight: 600; color: var(--ink-2); }
    td.win { background: var(--accent-soft) !important; font-weight: 650; color: var(--accent-deep); }

    /* ---------- Cards grid ---------- */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: .8rem; margin: 1rem 0; }
    .card {
      border: 1px solid var(--line); border-radius: var(--radius); padding: .95rem 1.05rem;
      background: var(--bg); box-shadow: var(--shadow);
      transition: box-shadow .15s ease, transform .15s ease, border-color .15s ease;
    }
    .card:hover { box-shadow: var(--shadow-up); transform: translateY(-1px); border-color: var(--accent-line); }
    .card > a { text-decoration: none; font-weight: 650; color: var(--ink); display: block; }
    .card > a:hover { color: var(--accent-deep); }
    .card .sub { margin: .35rem 0 0; font-size: .86rem; color: var(--muted); }

    /* ---------- Hero ---------- */
    .hero {
      background: linear-gradient(160deg, #f2faf7 0%, #fbfdfc 55%, #ffffff 100%);
      border-bottom: 1px solid var(--line);
    }
    .hero .wrap { padding: 2.6rem 1.1rem 2.4rem; }
    .hero h1 { max-width: 620px; }
    .hero .lead { margin-bottom: 1.3rem; }
    .btn {
      display: inline-block; background: var(--accent); color: #fff; text-decoration: none;
      font-weight: 650; font-size: .95rem; padding: .62rem 1.25rem; border-radius: 10px;
      box-shadow: var(--shadow); transition: background .15s ease;
    }
    .btn:hover { background: var(--accent-deep); }
    .btn-ghost { background: var(--bg); color: var(--accent-deep); border: 1px solid var(--accent-line); }
    .btn-ghost:hover { background: var(--accent-soft); }
    .btn-row { display: flex; flex-wrap: wrap; gap: .6rem; }

    /* ---------- Breadcrumbs / misc ---------- */
    .crumbs { font-size: .84rem; color: var(--muted); margin-bottom: .9rem; }
    .crumbs a { color: var(--muted); }
    .note {
      background: var(--accent-soft); border: 1px solid var(--accent-line); border-radius: var(--radius);
      padding: .75rem 1rem; font-size: .93rem; margin: 1rem 0;
    }
    .disclosure {
      background: var(--alt); border: 1px solid var(--line); border-radius: var(--radius);
      padding: .75rem 1rem; font-size: .83rem; color: var(--muted); margin: 1.6rem 0 0;
    }
    details.faq { border: 1px solid var(--line); border-radius: var(--radius); padding: 0; margin: .55rem 0; background: var(--bg); box-shadow: var(--shadow); }
    details.faq summary {
      cursor: pointer; font-weight: 600; padding: .8rem 1rem; list-style: none; position: relative; padding-right: 2.2rem;
    }
    details.faq summary::-webkit-details-marker { display: none; }
    details.faq summary::after { content: "+"; position: absolute; right: 1rem; top: .68rem; font-size: 1.15rem; color: var(--accent); font-weight: 700; }
    details.faq[open] summary::after { content: "–"; }
    details.faq div { padding: 0 1rem .85rem; color: var(--ink-2); }

    .filters { display: flex; flex-wrap: wrap; gap: .45rem; margin: 1rem 0; }
    .filters button {
      background: var(--bg); color: var(--ink-2); border: 1px solid var(--line); border-radius: 999px;
      padding: .38rem .95rem; font-size: .87rem; font-weight: 600; cursor: pointer; font-family: inherit;
      transition: all .12s ease;
    }
    .filters button:hover { border-color: var(--accent-line); color: var(--accent-deep); }
    .filters button.active { background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ---------- Footer ---------- */
    footer.site { border-top: 1px solid var(--line); background: var(--alt); margin-top: 2rem; }
    footer.site .wrap { padding: 2rem 1.1rem 2.4rem; display: grid; gap: 1.4rem; grid-template-columns: 1fr; }
    @media (min-width: 640px) { footer.site .wrap { grid-template-columns: 1.4fr 1fr; } }
    footer.site p { font-size: .84rem; color: var(--muted); margin: .35rem 0; }
    footer.site .flogo { font-weight: 800; color: var(--ink); font-size: 1rem; }
    footer.site .flogo b { color: var(--accent); }
    footer.site nav { display: flex; flex-direction: column; gap: .35rem; }
    footer.site nav a { font-size: .88rem; color: var(--ink-2); text-decoration: none; }
    footer.site nav a:hover { color: var(--accent-deep); }

    @media (max-width: 480px) {
      nav.main a { padding: .42rem .5rem; font-size: .86rem; }
      th, td { padding: .5rem .6rem; font-size: .88rem; }
    }
  </style>
</head>
<body>
  <header class="site">
    <div class="wrap">
      <a class="logo" href="/" aria-label="WattLibrary home">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="21" height="21" rx="5.5" fill="#0e8a63"/>
          <path d="M13.2 4.5 7.5 13h3.6l-1 6.5L16.5 10.5h-3.8l.5-6z" fill="#fff"/>
        </svg>
        Watt<b>Library</b>
      </a>
      <nav class="main">
        <a href="/power-stations/">Database</a>
        <a href="/compare/">Compare</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>
  <slot name="hero" />
  <main><div class="wrap"><slot /></div></main>
  <footer class="site">
    <div class="wrap">
      <div>
        <div class="flogo">Watt<b>Library</b></div>
        <p>An independent portable power station database. Specifications are compiled from manufacturer documentation and verified before publishing.</p>
        <p>© {new Date().getFullYear()} WattLibrary</p>
      </div>
      <nav aria-label="Footer">
        <a href="/power-stations/">All power stations</a>
        <a href="/compare/">Head-to-head comparisons</a>
        <a href="/about/">About & methodology</a>
      </nav>
    </div>
  </footer>
</body>
</html>
