---
const { title, description, schema } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#22201c" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="WattLibrary" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <style is:global>
    :root {
      --ink: #22201c; --ink-2: #45413a; --muted: #7b756b; --line: #e3ddd2;
      --accent: #a34a0e; --accent-deep: #82390a; --accent-soft: #f7ecdf; --accent-line: #e4c9a8;
      --bg: #fcfaf6; --alt: #f4efe6; --paper: #fffdf9;
      --radius: 6px;
      --serif: "Charter", "Bitstream Charter", "Sitka Text", Cambria, Georgia, serif;
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0; color: var(--ink); background: var(--bg);
      font: 16px/1.65 system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    }
    a { color: var(--accent-deep); text-decoration-thickness: 1px; text-underline-offset: 2px; }
    .wrap { max-width: 1024px; margin: 0 auto; padding: 0 1.1rem; }

    /* ---------- Header ---------- */
    header.site { background: var(--ink); }
    header.site .wrap { display: flex; align-items: center; gap: 1rem; height: 3.3rem; }
    .logo { display: flex; align-items: center; gap: .5rem; font-family: var(--serif); font-weight: 700; font-size: 1.18rem; color: #f6f1e7; text-decoration: none; }
    .logo svg { flex: none; }
    .logo b { color: #e8a55f; font-weight: 700; }
    nav.main { margin-left: auto; display: flex; gap: 1.1rem; }
    nav.main a { color: #cfc8ba; text-decoration: none; font-size: .93rem; }
    nav.main a:hover { color: #fff; text-decoration: underline; text-underline-offset: 4px; }

    /* ---------- Type ---------- */
    main .wrap { padding-top: 1.9rem; padding-bottom: 3.5rem; }
    h1, h2, h3 { font-family: var(--serif); letter-spacing: 0; }
    h1 { font-size: clamp(1.6rem, 4.2vw, 2.25rem); line-height: 1.15; margin: 0 0 .5rem; text-wrap: balance; font-weight: 700; }
    h2 { font-size: clamp(1.22rem, 2.6vw, 1.45rem); margin: 2.4rem 0 .8rem; font-weight: 700; }
    h3 { font-size: 1.05rem; margin: 1.2rem 0 .25rem; }
    p { margin: .5rem 0 .9rem; }
    .lead { font-size: 1.05rem; color: var(--ink-2); max-width: 660px; }
    .muted { color: var(--muted); }
    .eyebrow { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .09em; color: var(--accent); margin: 0 0 .4rem; }

    /* ---------- Chips ---------- */
    .pill {
      display: inline-block; background: transparent; color: var(--accent-deep);
      border: 1px solid var(--accent-line); border-radius: 3px;
      padding: .15rem .6rem; font-size: .8rem; font-weight: 600;
    }

    /* ---------- KPI ---------- */
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(128px, 1fr)); gap: .6rem; margin: 1.1rem 0 .4rem; }
    .kpi { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); padding: .65rem .85rem; font-size: .82rem; color: var(--muted); }
    .kpi b { display: block; font-family: var(--serif); font-size: 1.25rem; color: var(--ink); margin-bottom: .05rem; }

    /* ---------- Tables ---------- */
    .tbl { border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; margin: 1rem 0 1.4rem; background: var(--paper); }
    .tbl-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table { border-collapse: collapse; width: 100%; font-size: .93rem; }
    th, td { text-align: left; padding: .55rem .85rem; border-bottom: 1px solid var(--line); white-space: nowrap; }
    tbody th { white-space: normal; font-weight: 600; color: var(--ink-2); }
    tbody tr:last-child th, tbody tr:last-child td { border-bottom: 0; }
    thead th { background: var(--alt); font-weight: 700; font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-2); border-bottom: 2px solid var(--line); }
    td.win { background: var(--accent-soft) !important; font-weight: 650; color: var(--accent-deep); }

    /* ---------- Cards ---------- */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: .8rem; margin: 1rem 0; }
    .card { border: 1px solid var(--line); border-left: 3px solid var(--accent-line); border-radius: var(--radius); padding: .9rem 1rem; background: var(--paper); }
    .card:hover { border-left-color: var(--accent); }
    .card > a { text-decoration: none; font-weight: 650; color: var(--ink); display: block; }
    .card > a:hover { color: var(--accent-deep); text-decoration: underline; }
    .card .sub { margin: .35rem 0 0; font-size: .86rem; color: var(--muted); }

    /* ---------- Hero ---------- */
    .hero { background: var(--alt); border-bottom: 1px solid var(--line); }
    .hero .wrap { padding: 2.5rem 1.1rem 2.3rem; }
    .hero h1 { max-width: 640px; }
    .hero .lead { margin-bottom: 1.3rem; }
    .btn {
      display: inline-block; background: var(--accent); color: #fff; text-decoration: none;
      font-weight: 600; font-size: .95rem; padding: .6rem 1.2rem; border-radius: var(--radius);
    }
    .btn:hover { background: var(--accent-deep); }
    .btn-ghost { background: transparent; color: var(--accent-deep); border: 1px solid var(--accent-line); }
    .btn-ghost:hover { background: var(--accent-soft); }
    .btn-row { display: flex; flex-wrap: wrap; gap: .6rem; }

    /* ---------- Misc ---------- */
    .crumbs { font-size: .84rem; color: var(--muted); margin-bottom: .9rem; }
    .crumbs a { color: var(--muted); }
    .note { background: var(--accent-soft); border: 1px solid var(--accent-line); border-radius: var(--radius); padding: .7rem 1rem; font-size: .93rem; margin: 1rem 0; }
    .disclosure { background: var(--alt); border: 1px solid var(--line); border-radius: var(--radius); padding: .75rem 1rem; font-size: .83rem; color: var(--muted); margin: 1.6rem 0 0; }
    details.faq { border-bottom: 1px solid var(--line); margin: 0; }
    details.faq summary { cursor: pointer; font-weight: 600; padding: .75rem .2rem; list-style: none; position: relative; padding-right: 2rem; }
    details.faq summary::-webkit-details-marker { display: none; }
    details.faq summary::after { content: "+"; position: absolute; right: .4rem; top: .6rem; font-size: 1.15rem; color: var(--accent); }
    details.faq[open] summary::after { content: "–"; }
    details.faq div { padding: 0 .2rem .85rem; color: var(--ink-2); }

    .filters { display: flex; flex-wrap: wrap; gap: .45rem; margin: 1rem 0; }
    .filters button {
      background: var(--paper); color: var(--ink-2); border: 1px solid var(--line); border-radius: 3px;
      padding: .35rem .85rem; font-size: .87rem; font-weight: 600; cursor: pointer; font-family: inherit;
    }
    .filters button:hover { border-color: var(--accent-line); color: var(--accent-deep); }
    .filters button.active { background: var(--ink); border-color: var(--ink); color: #f6f1e7; }

    /* ---------- Footer ---------- */
    footer.site { border-top: 3px solid var(--ink); background: var(--alt); margin-top: 2rem; }
    footer.site .wrap { padding: 1.9rem 1.1rem 2.3rem; display: grid; gap: 1.4rem; grid-template-columns: 1fr; }
    @media (min-width: 640px) { footer.site .wrap { grid-template-columns: 1.4fr 1fr; } }
    footer.site p { font-size: .84rem; color: var(--muted); margin: .35rem 0; }
    footer.site .flogo { font-family: var(--serif); font-weight: 700; color: var(--ink); font-size: 1.05rem; }
    footer.site .flogo b { color: var(--accent); }
    footer.site nav { display: flex; flex-direction: column; gap: .35rem; }
    footer.site nav a { font-size: .88rem; color: var(--ink-2); }

    @media (max-width: 480px) {
      nav.main { gap: .7rem; }
      nav.main a { font-size: .86rem; }
      th, td { padding: .5rem .6rem; font-size: .88rem; }
    }
  </style>
</head>
<body>
  <header class="site">
    <div class="wrap">
      <a class="logo" href="/" aria-label="WattLibrary home">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="21" height="21" rx="4" fill="#e8a55f"/>
          <path d="M13.2 4.5 7.5 13h3.6l-1 6.5L16.5 10.5h-3.8l.5-6z" fill="#22201c"/>
        </svg>
        Watt<b>Library</b>
      </a>
      <nav class="main">
        <a href="/power-stations/">Database</a>
        <a href="/compare/">Compare</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>
  <slot name="hero" />
  <main><div class="wrap"><slot /></div></main>
  <footer class="site">
    <div class="wrap">
      <div>
        <div class="flogo">Watt<b>Library</b></div>
        <p>A structured database of portable power stations. Specs come from manufacturer documentation and manuals, and each listing links to its source.</p>
        <p>© {new Date().getFullYear()} WattLibrary</p>
      </div>
      <nav aria-label="Footer">
        <a href="/power-stations/">All power stations</a>
        <a href="/compare/">Head-to-head comparisons</a>
        <a href="/about/">About & methodology</a>
      </nav>
    </div>
  </footer>
</body>
</html>
